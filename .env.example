# Required in production
AUTH_SECRET=replace-with-a-long-random-secret
PORT=3000

# Recommended for Hostinger production
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-mysql-database
MYSQL_SSL=false

# Optional email settings for password reset and welcome emails
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Restaurant POV <noreply@yourdomain.com>

# Optional local override for JSON storage in development only
# RESTAURANTPOV_DATA_DIR=./data
