{
  "name": "antigravity",
  "private": true,
  "version": "0.0.0",
  "description": "Restaurant POV desktop and web order management app",
  "author": "Restaurant POV",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "node server/index.mjs --prod",
    "start": "node server/index.mjs --prod",
    "desktop:dev": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@react-spring/web": "^10.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "animejs": "^4.3.6",
    "bcryptjs": "^3.0.3",
    "express": "^5.1.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "mysql2": "^3.15.3",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "read-excel-file": "^7.0.2",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "velocity-animate": "^1.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.restaurantpov.desktop",
    "productName": "Restaurant POV",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
